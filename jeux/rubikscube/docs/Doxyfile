# Doxyfile for RubiksCube
# @author Maxime CHAUVEAU
# @date March 2026

DOXYFILE_ENCODING       = UTF-8

# ---------------------------------------------------------------------------
# Project metadata
# ---------------------------------------------------------------------------

PROJECT_NAME            = "RubiksCube"
PROJECT_NUMBER          = 2026.03.19-1
PROJECT_BRIEF           = "Rubik's Cube - 3D puzzle game"
PROJECT_LOGO            = 

OUTPUT_DIRECTORY        = ./html
HTML_OUTPUT             = html
GENERATE_LATEX          = NO

# ---------------------------------------------------------------------------
# Output configuration
# ---------------------------------------------------------------------------

CREATE_SUBDIRS         = YES
CREATE_SUBDIRS_LEVEL   = 2
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ABBREVIATE_BRIEF       = "The $name class" \
                         "The $name widget" \
                         "The $name file"
ALWAYS_DETAILED_SEC    = YES
INLINE_INHERITED_MEMB  = YES

# ---------------------------------------------------------------------------
# Path handling and stripping
# ---------------------------------------------------------------------------

FULL_PATH_NAMES         = YES
STRIP_FROM_PATH         = ../rubiksCube/
STRIP_FROM_INC_PATH     = include ../firstparty ../thirdparty

# ---------------------------------------------------------------------------
# Input files and scanning
# ---------------------------------------------------------------------------

USE_MDFILE_AS_MAINPAGE  = ../README.md
INPUT                   = .. \
                         ../include \
                         ../src \
                         makefile.md
RECURSIVE               = YES
FILE_PATTERNS           = *.c *.h *.md

EXCLUDE                = tests ../build ../thirdparty Makefile
EXCLUDE_SYMLINKS       = YES

SEARCH_INCLUDES        = YES
INCLUDE_PATH           = include ../firstparty ../thirdparty

# ---------------------------------------------------------------------------
# C-specific optimization and extraction
# ---------------------------------------------------------------------------

OPTIMIZE_OUTPUT_FOR_C   = YES
EXTRACT_ALL             = YES
EXTRACT_PRIVATE         = YES
EXTRACT_STATIC          = YES
EXTRACT_LOCAL_CLASSES   = YES
EXTRACT_LOCAL_METHODS   = YES

# ---------------------------------------------------------------------------
# HTML output
# ---------------------------------------------------------------------------

GENERATE_HTML           = YES
HTML_COLORSTYLE_HUE     = 200
HTML_COLORSTYLE_SAT     = 100
HTML_COLORSTYLE_GAMMA   = 80
HTML_TIMESTAMP          = YES
HTML_DYNAMIC_SECTIONS   = YES

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# ---------------------------------------------------------------------------
# Documentation layout
# ---------------------------------------------------------------------------

ALphabetical_INDEX      = YES
COLS_IN_ALPHA_INDEX     = 5
INTERNAL_DOCS           = YES

# ---------------------------------------------------------------------------
# Preprocessor
# ---------------------------------------------------------------------------

ENABLE_PREPROCESSING    = YES
MACRO_EXPANSION        = NO
EXPAND_ONLY_PREDEF      = NO
