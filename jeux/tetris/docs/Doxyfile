# Minimal Doxyfile
# @author Fshimi-Hawlk
# @date February 2026

DOXYFILE_ENCODING       = UTF-8

# ----------------------------------------------------------------
# Project metadata
# ----------------------------------------------------------------

PROJECT_NAME            = "Tetris"
PROJECT_NUMBER          = 2026.02.28-1 # <date of the commit>-<current commit count of the day>
PROJECT_BRIEF           = "Tetris Brief..."

# ----------------------------------------------------------------
# Output configuration
# ----------------------------------------------------------------

OUTPUT_DIRECTORY        = ./docs
HTML_OUTPUT             = html
GENERATE_LATEX          = NO

CREATE_SUBDIRS          = YES
CREATE_SUBDIRS_LEVEL    = 2

# ----------------------------------------------------------------
# Path handling and stripping
# ----------------------------------------------------------------

FULL_PATH_NAMES         = YES
STRIP_FROM_PATH         = ../
STRIP_FROM_INC_PATH     = include ../firstparty ../thirdparty

# ----------------------------------------------------------------
# Input files and scanning
# ----------------------------------------------------------------

USE_MDFILE_AS_MAINPAGE  = README.md
INPUT                   = README.md src include makefile.md make/internal-structure.md
RECURSIVE               = YES
FILE_PATTERNS           = *.c *.h *.md

EXCLUDE                 = tests docs build ../thirdparty Makefile
EXCLUDE_SYMLINKS        = YES

SEARCH_INCLUDES         = YES
INCLUDE_PATH            = include ../firstparty ../thirdparty

# ----------------------------------------------------------------
# C-specific optimization and extraction
# ----------------------------------------------------------------

OPTIMIZE_OUTPUT_FOR_C   = YES

EXTRACT_ALL             = YES
HIDE_UNDOC_MEMBERS      = NO
HIDE_UNDOC_CLASSES      = NO

PREDEFINED              = _DEBUG

# ----------------------------------------------------------------
# Source code visibility in documentation
# ----------------------------------------------------------------

SOURCE_BROWSER          = NO
INLINE_SOURCES          = NO
VERBATIM_HEADERS        = NO

# ----------------------------------------------------------------
# Graph generation
# ----------------------------------------------------------------

HAVE_DOT                = YES
DOT_NUM_THREADS         = 0

INCLUDE_GRAPH           = YES
INCLUDED_BY_GRAPH       = YES

COLLABORATION_GRAPH     = YES
DIRECTORY_GRAPH         = YES
DIR_GRAPH_MAX_DEPTH     = 1000

CALL_GRAPH              = NO
CALLER_GRAPH            = NO
CLASS_GRAPH             = NO

# Cosmetic / performance
DOT_IMAGE_FORMAT        = svg
INTERACTIVE_SVG         = YES
DOT_MULTI_TARGETS       = YES

# ----------------------------------------------------------------
# Performance / multi-core
# ----------------------------------------------------------------

NUM_PROC_THREADS        = 0